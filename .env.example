# ─── Datenbank ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/garmin_dashboard

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://your-app.railway.app
NEXTAUTH_SECRET=                  # openssl rand -base64 32

# ─── Garmin Sync Worker ───────────────────────────────────────────────────────
# AES-256 Fernet Key für Token-Verschlüsselung:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GARMIN_ENCRYPT_KEY=

# Garmin-Credentials (werden EINMALIG für den ersten Login benötigt,
# danach laufen alle Syncs über garth-Token-Cache)
GARMIN_EMAIL_DANIEL=
GARMIN_PASSWORD_DANIEL=            # nur für initialen Login, danach löschen
GARMIN_EMAIL_FRAU=
GARMIN_PASSWORD_FRAU=              # nur für initialen Login, danach löschen

# ─── App-Einstellungen ────────────────────────────────────────────────────────
NODE_ENV=production
TZ=Europe/Berlin
