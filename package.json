{
  "name": "garmin-training-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "rm -f next.config.ts && next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "psql $DATABASE_URL -f db/schema.sql",
    "db:seed": "psql $DATABASE_URL -f db/seed.sql",
    "db:reset": "psql $DATABASE_URL -c 'DROP SCHEMA public CASCADE; CREATE SCHEMA public;' && npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "next-auth": "^4.24.7",
    "pg": "^8.12.0",
    "chart.js": "^4.4.3",
    "react-chartjs-2": "^5.2.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "bcryptjs": "^2.4.3",
    "zod": "^3.23.8",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/pg": "^8.11.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/web-push": "^3.3.3",
    "typescript": "^5.4.5",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "tailwindcss": "^3.4.4",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38"
  }
}
